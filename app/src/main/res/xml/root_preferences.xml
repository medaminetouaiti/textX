<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <Preference
        android:icon="@mipmap/ic_launcher_round"
        android:summary="Made with &#10084; in Tunisia"
        android:title="@string/app_name" />
    <PreferenceCategory android:title="Settings">

        <SwitchPreference
            android:defaultValue="false"
            android:key="@string/Pref_isMultiline"
            android:title="Single Line Text"
            android:summary="After scan, convert multiline text paragraph into single line" />

        <ListPreference
            android:defaultValue="0"
            android:entries="@array/ocr_language"
            android:entryValues="@array/ocr_language_values"
            android:key="ocrlang"
            android:title="OCR Language" />

    </PreferenceCategory>
    <PreferenceCategory android:title="About">
        <Preference
            android:key="ratekey"
            android:title="Rate App 5 Stars" />

        <Preference
            android:summary="@string/app_version_name"
            android:title="Version" />

        <Preference
            android:summary="@string/app_version_code"
            android:title="Build Number" />
        <Preference
            android:key="appupdate"
            android:title="Check for Update" />

    </PreferenceCategory>

    <PreferenceCategory android:title="More">
        <Preference
            android:key="secpri"
            android:title="Privacy Policy" />

    </PreferenceCategory>
</PreferenceScreen>
